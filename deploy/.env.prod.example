# Copie para /opt/compliance/prod/.env na VM.
# O pipeline ATUALIZA somente APP_IMAGE a cada deploy — demais valores ficam estáticos.

SPRING_PROFILES_ACTIVE=prod
APP_HOST_PORT=8081
APP_IMAGE=fiapdevops.azurecr.io/compliance:prod

POSTGRES_DB=compliance
POSTGRES_USER=compliance_user
POSTGRES_PASSWORD=troque-me-prod

RABBITMQ_USER=guest
RABBITMQ_PASS=guest

JWT_SECRET=troque-me-por-um-segredo-forte-de-prod
