# Copie para /opt/compliance/staging/.env na VM.
# O pipeline ATUALIZA somente APP_IMAGE a cada deploy — demais valores ficam estáticos.

SPRING_PROFILES_ACTIVE=staging
APP_HOST_PORT=8080
APP_IMAGE=fiapdevops.azurecr.io/compliance:staging

POSTGRES_DB=compliance
POSTGRES_USER=compliance_user
POSTGRES_PASSWORD=troque-me-staging

RABBITMQ_USER=guest
RABBITMQ_PASS=guest

JWT_SECRET=troque-me-por-um-segredo-forte-de-staging
