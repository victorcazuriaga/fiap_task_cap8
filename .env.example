# Copy to .env.staging or .env.prod and fill in real values.
# These files MUST NOT be committed (see .gitignore).

# ===== Application =====
SPRING_PROFILES_ACTIVE=staging
IMAGE=ghcr.io/<your-user>/compliance:staging

# ===== PostgreSQL =====
# Local dev (docker-compose):
POSTGRES_DB=compliance
POSTGRES_USER=compliance_user
POSTGRES_PASSWORD=compliance_pass

# Staging/Prod (Azure Database for PostgreSQL Flexible Server):
# Use sslmode=require; Azure requires TLS.
SPRING_DATASOURCE_URL=jdbc:postgresql://<server>.postgres.database.azure.com:5432/compliance?sslmode=require
SPRING_DATASOURCE_USERNAME=changeme
SPRING_DATASOURCE_PASSWORD=changeme
DB_POOL_MAX_SIZE=10
DB_POOL_MIN_IDLE=2

# ===== RabbitMQ =====
SPRING_RABBITMQ_HOST=rabbit-host
SPRING_RABBITMQ_PORT=5672
SPRING_RABBITMQ_USERNAME=changeme
SPRING_RABBITMQ_PASSWORD=changeme
RABBITMQ_SSL_ENABLED=false

# ===== Security =====
# Must be at least 32 chars, random. In real deploys fetch from Azure Key Vault.
JWT_SECRET=change-me-use-a-real-secret-manager

# ===== Flyway (maven plugin, only for manual/CI migrations) =====
FLYWAY_URL=jdbc:postgresql://<server>.postgres.database.azure.com:5432/compliance?sslmode=require
FLYWAY_USER=changeme
FLYWAY_PASSWORD=changeme
FLYWAY_SCHEMA=public
